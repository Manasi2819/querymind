# ══════════════════════════════════════════════════════════════════════════════
#  QueryMind Frontend — .dockerignore
# ══════════════════════════════════════════════════════════════════════════════

# Node.js artifacts
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build output (generated inside the container)
dist/
.vite/
.eslintcache

# Environment files (not needed in Docker — env is set via compose)
.env
.env.*
.env.local
.env.development

# OS artifacts
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
