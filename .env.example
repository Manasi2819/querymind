# ══════════════════════════════════════════════════════════════════════════════
#  QueryMind — Docker Environment Template
#  Copy this file to .env before running: docker compose up --build -d
#
#  IMPORTANT: Never commit .env to Git!
# ══════════════════════════════════════════════════════════════════════════════

# ── LLM Configuration ──────────────────────────────────────────────────────
# Choose: "ollama" | "openai" | "anthropic" | "gemini" | "groq"
LLM_PROVIDER=ollama

# Ollama settings — IMPORTANT: use "ollama" hostname (Docker service name)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_EMBED_MODEL=nomic-embed-text

# OpenAI (optional — leave blank if not using)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5-instant

# Anthropic (optional — leave blank if not using)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-4-6-sonnet

# Google Gemini (optional — leave blank if not using)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash

# Groq (optional — leave blank if not using)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# ── Database Configuration (Metadata) ───────────────────────────────────────
# Default: SQLite (Persistent via Docker volumes). 
# The application automatically creates the database file at this location.
DATABASE_URL=sqlite:////app/data/querymind_metadata.db

# Optional: MySQL / PostgreSQL
# If you want to use an external database, uncomment and set this:
# DATABASE_URL=mysql+pymysql://user:password@host:3306/dbname
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── ChromaDB ────────────────────────────────────────────────────────────────
# Using PersistentClient (file-based) via Docker volume — no HTTP needed.
CHROMA_PERSIST_DIR=/app/chroma_db

# ── File uploads ────────────────────────────────────────────────────────────
UPLOAD_DIR=/app/uploads

# ── JWT Auth ────────────────────────────────────────────────────────────────
# Generate a strong random key: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME_generate_a_strong_random_key
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ── Encryption ──────────────────────────────────────────────────────────────
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=CHANGE_ME_generate_a_fernet_key

# ── Admin credentials ───────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_strong_password

# ── Logging ──────────────────────────────────────────────────────────────────
# Set to "true" for local development to save logs to /logs folder.
# Set to "false" for Docker/Deployment to prevent local file I/O.
ENABLE_FILE_LOGGING=false
