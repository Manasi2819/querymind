# ── LLM Configuration ──────────────────────────────────────
# Choose: "ollama" or "openai" or "anthropic" or "gemini" or "groq"
LLM_PROVIDER=ollama

# Ollama settings (used when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=phi3:mini
OLLAMA_EMBED_MODEL=nomic-embed-text

# OpenAI settings (used when LLM_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Anthropic settings (used when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-haiku-20240307

# Gemini settings (used when LLM_PROVIDER=gemini)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Groq settings (used when LLM_PROVIDER=groq)
GROQ_API_KEY=
GROQ_MODEL=llama3-8b-8192

# ── Database (single URL — database-agnostic) ──────────────
# QueryMind auto-creates the target database if it does not exist.
# Simply set DATABASE_URL to switch between SQLite, MySQL, or PostgreSQL.
# No code changes are needed.
#
# --- SQLite (default, local development) ---
DATABASE_URL=sqlite:///./querymind_metadata.db
#
# --- MySQL (local server or self-hosted) ---
# DATABASE_URL=mysql+pymysql://username:password@localhost:3306/queryminddb
#
# --- PostgreSQL (AWS RDS / Supabase / Google Cloud SQL) ---
# DATABASE_URL=postgresql+psycopg2://username:password@host:5432/queryminddb

# ── Redis (for Celery task queue) ──────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Auth ────────────────────────────────────────────────────
JWT_SECRET_KEY=change_this_to_a_long_random_secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ── ChromaDB ────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_db

# ── File uploads ────────────────────────────────────────────
UPLOAD_DIR=./uploads

# ── Admin credentials ───────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
