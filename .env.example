# ── LLM Configuration ──────────────────────────────────────
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=phi3:mini
OLLAMA_EMBED_MODEL=nomic-embed-text

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-haiku-20240307

GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

GROQ_API_KEY=
GROQ_MODEL=llama3-8b-8192

# ── Database ────────────────────────────────────────────────
# Use: sqlite:///./querymind_metadata.db OR your production connection string
DATABASE_URL=sqlite:///./querymind_metadata.db

# ── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Auth ────────────────────────────────────────────────────
JWT_SECRET_KEY=change_this_to_a_long_random_secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ── Encryption ──────────────────────────────────────────────
# Generate a key using: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# ── ChromaDB ────────────────────────────────────────────────
# Unified root folder path
CHROMA_PERSIST_DIR=../chroma_db

# ── File uploads ────────────────────────────────────────────
UPLOAD_DIR=./uploads

# ── Admin credentials ───────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ── Database Credentials ────────────────────────────────────
POSTGRES_PASSWORD=changeme
