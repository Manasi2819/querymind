# ══════════════════════════════════════════════════════════════════════════════
#  QueryMind — Docker Environment Template
#  Copy this file to .env before running: docker compose up --build -d
#
#  IMPORTANT: Never commit .env to Git!
# ══════════════════════════════════════════════════════════════════════════════

# ── LLM Configuration ──────────────────────────────────────────────────────
# Choose: "ollama" | "openai" | "anthropic" | "gemini" | "groq"
LLM_PROVIDER=ollama

# Ollama settings — IMPORTANT: use "ollama" hostname (Docker service name)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_EMBED_MODEL=nomic-embed-text

# OpenAI (optional — leave blank if not using)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Anthropic (optional — leave blank if not using)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-haiku-20240307

# Google Gemini (optional — leave blank if not using)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Groq (optional — leave blank if not using)
GROQ_API_KEY=
GROQ_MODEL=llama3-8b-8192

# ── MySQL Database (Docker container) ──────────────────────────────────────
# These override the DATABASE_URL in docker-compose.yml automatically.
MYSQL_ROOT_PASSWORD=rootpassword_CHANGE_ME
MYSQL_DATABASE=queryminddb
MYSQL_USER=querymind_user
MYSQL_PASSWORD=changeme_CHANGE_ME

# The DATABASE_URL is built automatically in docker-compose.yml from above.
# Only set this manually if you want to use an EXTERNAL database.
# DATABASE_URL=mysql+pymysql://querymind_user:changeme@mysql:3306/queryminddb

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── ChromaDB ────────────────────────────────────────────────────────────────
# Using PersistentClient (file-based) via Docker volume — no HTTP needed.
CHROMA_PERSIST_DIR=/app/chroma_db

# ── File uploads ────────────────────────────────────────────────────────────
UPLOAD_DIR=/app/uploads

# ── JWT Auth ────────────────────────────────────────────────────────────────
# Generate a strong random key: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME_generate_a_strong_random_key
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ── Encryption ──────────────────────────────────────────────────────────────
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=CHANGE_ME_generate_a_fernet_key

# ── Admin credentials ───────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_strong_password
