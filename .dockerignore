# ══════════════════════════════════════════════════════════════════════════════
#  QueryMind — Root .dockerignore
# ══════════════════════════════════════════════════════════════════════════════

# Python
venv/
backend/venv/
**/__pycache__/
**/*.pyc
**/*.pyo
backend/.pytest_cache/
backend/*.db
backend/chroma_db/
backend/uploads/
backend/scratch/

# Node
frontend/node_modules/
frontend/dist/
frontend/.vite/

# Git
.git/
.gitignore
.gitattributes

# Secrets
.env
.env.*
*.env

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Logs
*.log

# Runtime data (volumes handle these)
chroma_db/
data/
uploads/
redis_data/
ollama_data/

# Docs / non-essential
docs/
*.md

