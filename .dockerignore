# ══════════════════════════════════════════════════════════════════════════════
#  QueryMind — Root .dockerignore
#  Applied to the root build context (if you ever build from root).
# ══════════════════════════════════════════════════════════════════════════════

# Python
backend/venv/
backend/__pycache__/
backend/*.pyc
backend/.pytest_cache/
backend/*.db
backend/chroma_db/
backend/uploads/
backend/scratch/

# Node
frontend/node_modules/
frontend/dist/
frontend/.vite/

# Git
.git/
.gitignore

# Secrets
.env
.env.*
*.env

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Logs
*.log

# Runtime data (volumes handle these)
chroma_db/
uploads/
redis_data/
ollama_data/
